# 1. JWT (Секретный ключ должен быть длинным, не менее 256 бит / 32 символа)
JWT_SECRET_KEY=mySuperSecretKeyForJwtTokensThatIsAtLeast32CharactersLong12345

# 2. Подключение к локальной базе данных PostgreSQL
# Замените 'demo_db' на имя вашей базы данных в PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/demo_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=5432

